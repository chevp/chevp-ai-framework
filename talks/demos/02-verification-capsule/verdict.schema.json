{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Gatekeeper Verdict",
  "description": "Strukturiertes Ergebnis einer Gate-Pruefung. Maschinenlesbar, nicht Freitext.",
  "type": "object",
  "additionalProperties": false,
  "required": ["artifact", "verdict", "findings"],
  "properties": {
    "artifact": {
      "type": "string",
      "description": "Pfad/ID des geprueften Artefakts."
    },
    "verdict": {
      "type": "string",
      "enum": ["pass", "conditional", "block"],
      "description": "Das Gesamturteil."
    },
    "findings": {
      "type": "array",
      "description": "Belege fuer das Urteil. Bei 'pass' leer.",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["criterion", "severity", "detail"],
        "properties": {
          "criterion": { "type": "string", "description": "Verletztes Kriterium, z.B. C1." },
          "severity": { "type": "string", "enum": ["block", "conditional"] },
          "detail": { "type": "string", "description": "Knappe Begruendung." }
        }
      }
    }
  }
}
